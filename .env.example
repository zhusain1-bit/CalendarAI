# ─── Server (server/.env) ────────────────────────────────────────────────────

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Microsoft OAuth (Azure AD App Registration)
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...
MICROSOFT_TENANT_ID=common

# Stripe (Dashboard → Developers → API Keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# RevenueCat (Dashboard → Apps → Webhook)
REVENUECAT_WEBHOOK_AUTH_HEADER=...

# Auth
JWT_SECRET=replace-with-256-bit-random-secret

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/calify

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:8081,https://calify.app

# ─── App (app/.env) ───────────────────────────────────────────────────────────

# Backend API
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Google OAuth (same client ID as above — safe to expose)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Microsoft OAuth
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=...

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_...
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_...

# Stripe (publishable key — safe to expose)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
